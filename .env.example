# ASANA_PAT: Asana Personal Access Token
ASANA_PAT=

# META_ACCESS_TOKEN: Meta Ads API Access Token
META_ACCESS_TOKEN=

# META_AD_ACCOUNT_ID: Meta Ad Account ID (e.g., act_123456789)
META_AD_ACCOUNT_ID=

# META_PAGE_ID: Meta Page ID for the ad
META_PAGE_ID=

# META_CUSTOM_AUDIENCE_ID: ID of the custom audience to target
META_CUSTOM_AUDIENCE_ID=

# META_EXCLUDE_AUDIENCE_ID: ID of the audience to exclude (e.g., purchase website audience)
META_EXCLUDE_AUDIENCE_ID=

# APP_URL: The URL where this applet is hosted.
APP_URL=
